# apps/api/.env
PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://robotops:robotops@localhost:5432/robotops?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=robotops-dev-secret
NATS_URL=nats://localhost:4222
NATS_STREAM=ROBOTOPS_STREAM
NATS_SUBJECT_TELEMETRY=ingest.telemetry.v1
ROLLUP_JOB_INTERVAL_SECONDS=300
ALERT_ENGINE_INTERVAL_SECONDS=15
TIMESCALE_RAW_RETENTION_DAYS=30
TIMESCALE_ROLLUP_RETENTION_DAYS=180

# apps/web/.env.local
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=robotops-nextauth-secret
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
