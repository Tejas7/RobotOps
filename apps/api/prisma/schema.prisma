generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  robot_state
  robot_event
  task_status
}

enum Severity {
  info
  warning
  major
  critical
}

enum Category {
  navigation
  traffic
  battery
  connectivity
  hardware
  safety
  integration
}

model Tenant {
  id            String          @id
  name          String
  plan          String
  createdAt     DateTime
  users         User[]
  sites         Site[]
  floorplans    Floorplan[]
  zones         Zone[]
  vendors       RobotVendor[]
  robots        Robot[]
  robotPathPoints RobotPathPoint[]
  missions      Mission[]
  incidents     Incident[]
  assets        Asset[]
  proximities   ProximityEvent[]
  integrations  Integration[]
  integrationTestRuns IntegrationTestRun[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  savedViews    SavedView[]
  roleDashboardDefaults RoleDashboardDefault[]
  dashboardConfigs DashboardConfig[]
  copilotThreads CopilotThread[]
  canonicalMessages CanonicalMessage[]
  ingestionEvents IngestionEvent[]
  telemetryDeadLetters TelemetryDeadLetter[]
  siteAnalyticsRollups SiteAnalyticsRollupHourly[]
  tenantAnalyticsRollups TenantAnalyticsRollupHourly[]
  alertRules AlertRule[]
  alertPolicies AlertPolicy[]
  alertPolicySteps AlertPolicyStep[]
  alertEvents AlertEvent[]
  alertDeliveries AlertDelivery[]
  roleScopeOverrides RoleScopeOverride[]
  robotLastStates RobotLastState[]
  siteSettings SiteSetting[]
  vendorSiteMaps VendorSiteMap[]
  taskLastStatuses TaskLastStatus[]
  messageDedupeWindows MessageDedupeWindow[]
  adapterHealthStates AdapterHealthState[]
  adapterReplayRuns AdapterReplayRun[]
  adapterReplayRunEvents AdapterReplayRunEvent[]
}

model User {
  id          String   @id
  tenantId    String
  email       String   @unique
  name        String
  password    String
  role        String
  permissions String[]
  createdAt   DateTime
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Site {
  id         String      @id
  tenantId   String
  name       String
  address    String
  timezone   String
  createdAt  DateTime
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floorplans Floorplan[]
  robots     Robot[]
  missions   Mission[]
  incidents  Incident[]
  assets     Asset[]
  proximities ProximityEvent[]
  analyticsRollups SiteAnalyticsRollupHourly[]
  robotLastStates RobotLastState[]
  siteSettings SiteSetting[]
  vendorSiteMaps VendorSiteMap[]
  taskLastStatuses TaskLastStatus[]
  messageDedupeWindows MessageDedupeWindow[]
  adapterHealthStates AdapterHealthState[]
}

model Floorplan {
  id                  String    @id
  tenantId            String
  siteId              String
  name                String
  imageUrl            String
  scaleMetersPerPixel Float
  originX             Float
  originY             Float
  rotationDegrees     Float
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  zones               Zone[]
  vendorSiteMaps      VendorSiteMap[]
}

model Zone {
  id                  String    @id
  tenantId            String
  floorplanId         String
  name                String
  type                String
  polygon             Json
  maxSpeedMps         Float
  requiresOperatorAck Boolean
  allowedRobotTags    String[]
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floorplan           Floorplan @relation(fields: [floorplanId], references: [id], onDelete: Cascade)
  proximities         ProximityEvent[]
}

model RobotVendor {
  id                 String  @id
  tenantId           String
  name               String
  integrationType    String
  supportedProtocols String[]
  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  robots             Robot[]
}

model Robot {
  id            String   @id
  tenantId      String
  siteId        String
  vendorId      String
  name          String
  model         String
  serial        String
  tags          String[]
  status        String
  batteryPercent Int
  lastSeenAt    DateTime
  floorplanId   String
  x             Float
  y             Float
  headingDegrees Float
  confidence    Float
  cpuPercent    Int
  memoryPercent Int
  tempC         Int
  networkRssi   Int
  diskPercent   Int
  capabilities  String[]
  connection    String
  ip            String
  firmware      String
  agentVersion  String
  edgeId        String?
  createdAt     DateTime
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  vendor        RobotVendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  missions      Mission[]
  missionEvents MissionEvent[]
  incidents     Incident[]
  telemetries   TelemetryPoint[]
  pathPoints    RobotPathPoint[]
  proximities   ProximityEvent[]
  lastStates    RobotLastState[]
}

model SiteSetting {
  tenantId                       String
  siteId                         String
  robotOfflineAfterSeconds       Int      @default(15)
  robotStatePublishPeriodSeconds Int      @default(2)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  tenant                         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([tenantId, siteId])
}

model VendorSiteMap {
  id                 String   @id
  tenantId           String
  siteId             String
  vendor             String
  vendorMapId        String?
  vendorMapName      String?
  robotopsFloorplanId String
  scale              Float    @default(1)
  rotationDegrees    Float    @default(0)
  translateX         Float    @default(0)
  translateY         Float    @default(0)
  createdBy          String
  updatedBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site               Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  robotopsFloorplan  Floorplan @relation(fields: [robotopsFloorplanId], references: [id], onDelete: Restrict)

  @@index([tenantId, siteId, vendor, vendorMapId])
  @@index([tenantId, siteId, vendor, vendorMapName])
}

model RobotLastState {
  tenantId                   String
  siteId                     String
  robotId                    String
  name                       String
  vendor                     String
  model                      String
  serial                     String
  tags                       String[]
  status                     String
  batteryPercent             Int
  lastSeenAt                 DateTime
  floorplanId                String
  x                          Float
  y                          Float
  headingDegrees             Float
  confidence                 Float
  healthScore                Int
  cpuPercent                 Int
  memoryPercent              Int
  tempC                      Int
  diskPercent                Int
  networkRssi                Int
  currentTaskId              String?
  currentTaskState           String?
  currentTaskPercentComplete Int?
  lastStateTimestamp         DateTime?
  lastStateSequence          Int?
  lastStateMessageId         String?
  updatedAt                  DateTime @updatedAt
  tenant                     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  robot                      Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)

  @@id([tenantId, siteId, robotId])
  @@index([tenantId, siteId, status])
  @@index([tenantId, siteId, vendor])
  @@index([tenantId, siteId, floorplanId])
  @@index([tenantId, siteId, updatedAt])
}

model TaskLastStatus {
  tenantId         String
  siteId           String
  taskId           String
  state            String
  percentComplete  Int?
  updatedAtLogical DateTime
  lastSequence     Int?
  lastMessageId    String?
  message          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  mission          Mission  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([tenantId, siteId, taskId])
  @@index([tenantId, siteId, updatedAtLogical])
  @@index([tenantId, taskId])
}

model MessageDedupeWindow {
  id            String      @id
  tenantId      String
  siteId        String
  messageType   MessageType
  entityId      String
  dedupeKey     String
  windowSeconds Int
  firstSeenAt   DateTime
  expiresAt     DateTime
  lastMessageId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site          Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, siteId, messageType, entityId, dedupeKey])
  @@index([tenantId, expiresAt])
  @@index([tenantId, siteId, messageType, entityId])
}

model Mission {
  id                 String        @id
  tenantId           String
  siteId             String
  name               String
  type               String
  priority           String
  createdByUserId    String
  assignedRobotId    String?
  state              String
  startTime          DateTime?
  endTime            DateTime?
  durationS          Int
  distanceM          Int
  stopsCount         Int
  interventionsCount Int
  energyUsedWh       Int
  routeWaypoints     Json
  routePolyline      Json
  failureCode        String?
  failureMessage     String?
  lastEventId        String?
  createdAt          DateTime @default(now())
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site               Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assignedRobot      Robot?        @relation(fields: [assignedRobotId], references: [id], onDelete: SetNull)
  missionEvents      MissionEvent[]
  incidents          Incident[]
  taskLastStatuses   TaskLastStatus[]
}

model MissionEvent {
  id         String   @id
  missionId  String
  robotId    String
  timestamp  DateTime
  type       String
  payload    Json
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  robot      Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)
}

model Incident {
  id             String          @id
  tenantId       String
  siteId         String
  robotId        String?
  missionId      String?
  severity       String
  category       String
  status         String
  title          String
  description    String
  createdAt      DateTime
  acknowledgedBy String?
  resolvedAt     DateTime?
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  robot          Robot?          @relation(fields: [robotId], references: [id], onDelete: SetNull)
  mission        Mission?        @relation(fields: [missionId], references: [id], onDelete: SetNull)
  timeline       IncidentEvent[]
}

model IncidentEvent {
  id         String   @id
  incidentId String
  timestamp  DateTime
  type       String
  message    String
  meta       Json
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model Asset {
  id             String   @id
  tenantId       String
  siteId         String
  type           String
  name           String
  tags           String[]
  floorplanId    String
  x              Float
  y              Float
  headingDegrees Float
  confidence     Float
  lastSeenAt     DateTime
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  proximityEvents ProximityEvent[]
}

model ProximityEvent {
  id        String   @id
  tenantId  String
  siteId    String
  timestamp DateTime
  robotId   String
  assetId   String
  distanceM Float
  riskLevel String
  zoneId    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  robot     Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  zone      Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
}

model ApiKey {
  id         String   @id
  tenantId   String
  name       String
  scopes     String[]
  createdAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id
  tenantId    String
  type        String
  name        String
  status      String
  config      Json
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testRuns    IntegrationTestRun[]
}

model IntegrationTestRun {
  id            String      @id
  integrationId String
  tenantId      String
  status        String
  message       String
  details       Json
  createdAt     DateTime
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AdapterHealthState {
  id            String   @id
  tenantId      String
  siteId        String
  vendor        String
  adapterName   String
  status        String
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  lastRunId     String?
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, siteId, vendor, adapterName])
  @@index([tenantId, updatedAt])
}

model AdapterReplayRun {
  id             String   @id
  tenantId       String
  captureId      String
  status         String
  startedAt      DateTime
  endedAt        DateTime?
  acceptedCount  Int      @default(0)
  duplicateCount Int      @default(0)
  failedCount    Int      @default(0)
  options        Json
  errorSummary   String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events         AdapterReplayRunEvent[]

  @@index([tenantId, startedAt])
}

model AdapterReplayRunEvent {
  id          String          @id
  tenantId    String
  runId       String
  messageId   String?
  messageType MessageType?
  result      String
  error       String?
  createdAt   DateTime        @default(now())
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run         AdapterReplayRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, messageId])
  @@index([tenantId, createdAt])
}

model CanonicalMessage {
  id              String       @id
  tenantId        String
  siteId          String
  messageId       String
  schemaVersion   Int
  messageType     MessageType
  timestamp       DateTime
  sourceType      String
  sourceId        String
  vendor          String
  protocol        String
  entityType      String
  robotId         String
  severity        Severity?
  category        Category?
  payload         Json
  rawEnvelope     Json
  createdAt       DateTime     @default(now())
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingestionEvents IngestionEvent[]

  @@unique([tenantId, messageId])
  @@index([tenantId, siteId, messageType, timestamp])
  @@index([tenantId, sourceId, timestamp])
}

model IngestionEvent {
  id                String            @id
  tenantId          String
  canonicalMessageId String?
  source            String
  dedupeKey         String
  status            String
  payload           Json
  error             String?
  createdAt         DateTime          @default(now())
  processedAt       DateTime?
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  canonicalMessage  CanonicalMessage? @relation(fields: [canonicalMessageId], references: [id], onDelete: SetNull)

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, canonicalMessageId])
}

model TelemetryDeadLetter {
  id        String   @id
  tenantId  String
  source    String
  payload   Json
  error     String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model AuditLog {
  id           String   @id
  tenantId     String
  timestamp    DateTime
  actorType    String
  actorId      String
  action       String
  resourceType String
  resourceId   String
  diff         Json
  ip           String
  userAgent    String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SavedView {
  id         String   @id
  tenantId   String
  createdBy  String
  page       String
  name       String
  filters    Json
  layout     Json
  isShared   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaults   RoleDashboardDefault[]
}

model RoleDashboardDefault {
  id          String    @id
  tenantId    String
  role        String
  page        String
  savedViewId String
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  savedView   SavedView @relation(fields: [savedViewId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, page])
}

model DashboardConfig {
  id            String   @id
  tenantId      String
  name          String
  schemaVersion String
  widgets       Json
  rules         Json
  appliesTo     Json
  isActive      Boolean  @default(false)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SiteAnalyticsRollupHourly {
  id                 String   @id
  tenantId           String
  siteId             String
  bucketStart        DateTime
  missionsTotal      Int
  missionsSucceeded  Int
  incidentsOpen      Int
  interventionsCount Int
  fleetSize          Int
  uptimePercent      Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site               Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, siteId, bucketStart])
  @@index([tenantId, bucketStart])
  @@index([tenantId, siteId, bucketStart])
}

model TenantAnalyticsRollupHourly {
  id                 String   @id
  tenantId           String
  bucketStart        DateTime
  missionsTotal      Int
  missionsSucceeded  Int
  incidentsOpen      Int
  interventionsCount Int
  fleetSize          Int
  uptimePercent      Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, bucketStart])
  @@index([tenantId, bucketStart])
}

model AlertPolicy {
  id          String            @id
  tenantId    String
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps       AlertPolicyStep[]
  rules       AlertRule[]
  events      AlertEvent[]

  @@index([tenantId, isActive])
}

model AlertPolicyStep {
  id          String       @id
  tenantId    String
  policyId    String
  orderIndex  Int
  delaySeconds Int
  channel     String
  target      String
  severityMin String?
  template    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  policy      AlertPolicy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries  AlertDelivery[]

  @@unique([policyId, orderIndex])
  @@index([tenantId, policyId])
}

model AlertRule {
  id         String      @id
  tenantId   String
  name       String
  eventType  String
  policyId   String
  priority   Int         @default(100)
  isActive   Boolean     @default(true)
  severity   String?
  category   String?
  siteId     String?
  conditions Json
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy     AlertPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  events     AlertEvent[]

  @@index([tenantId, isActive, priority])
  @@index([tenantId, eventType])
}

model AlertEvent {
  id             String          @id
  tenantId       String
  ruleId         String?
  policyId       String?
  incidentId     String?
  state          String
  severity       String
  title          String
  payload        Json
  triggeredAt    DateTime
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule           AlertRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  policy         AlertPolicy?    @relation(fields: [policyId], references: [id], onDelete: SetNull)
  deliveries     AlertDelivery[]

  @@index([tenantId, state, triggeredAt])
  @@index([tenantId, incidentId])
}

model AlertDelivery {
  id           String          @id
  tenantId     String
  alertEventId String
  policyStepId String?
  attempt      Int             @default(1)
  state        String
  channel      String
  target       String
  scheduledFor DateTime
  sentAt       DateTime?
  message      String
  error        String?
  details      Json
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alertEvent   AlertEvent      @relation(fields: [alertEventId], references: [id], onDelete: Cascade)
  policyStep   AlertPolicyStep? @relation(fields: [policyStepId], references: [id], onDelete: SetNull)

  @@index([tenantId, state, scheduledFor])
  @@index([tenantId, alertEventId])
}

model RoleScopeOverride {
  id          String   @id
  tenantId    String
  role        String
  allowScopes String[]
  denyScopes  String[]
  createdBy   String
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role])
  @@index([tenantId, role])
}

model CopilotThread {
  id        String          @id
  tenantId  String
  siteId    String?
  createdBy String
  createdAt DateTime
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages  CopilotMessage[]
}

model CopilotMessage {
  id        String   @id
  threadId  String
  timestamp DateTime
  role      String
  content   String
  toolCalls Json
  citations Json
  thread    CopilotThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model RobotPathPoint {
  id             String   @id
  tenantId       String
  robotId        String
  floorplanId    String
  x              Float
  y              Float
  headingDegrees Float
  confidence     Float
  timestamp      DateTime
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  robot          Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)

  @@index([tenantId, robotId, timestamp])
  @@index([tenantId, floorplanId, timestamp])
}

model TelemetryPoint {
  id         String   @id
  tenantId   String
  robotId    String
  metric     String
  value      Float
  timestamp  DateTime
  robot      Robot    @relation(fields: [robotId], references: [id], onDelete: Cascade)

  @@index([robotId, metric, timestamp])
  @@index([tenantId, metric, timestamp])
  @@index([tenantId, robotId, metric, timestamp])
}
