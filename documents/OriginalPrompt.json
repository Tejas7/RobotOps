{
  "project": {
    "name": "RobotOps",
    "tagline": "Robotics operations and orchestration dashboard for heterogeneous fleets",
    "positioning": {
      "one_liner": "A secure, scalable robot operations platform for monitoring, diagnostics, mission tracking, orchestration, and facility aware insights.",
      "target_users": [
        "Enterprise operations managers running robots across facilities",
        "Robotics engineering teams supporting deployments in the field",
        "System integrators connecting robots with WMS, ERP, WES, and facility systems",
        "Remote operators handling exceptions and teleoperation"
      ],
      "product_principles": [
        "Single pane of glass for heterogeneous robots and sites",
        "Facility context first: everything happens somewhere",
        "Operational clarity: incidents, root cause hints, and next action",
        "Engineer friendly: APIs, audit logs, configuration as code",
        "Security and tenancy by default"
      ],
      "explicit_constraints": [
        "Do not copy any vendor UI, branding, icons, layout, or text verbatim",
        "Create an original visual design system and information architecture",
        "Implement in a clean room manner using only this specification",
        "Functionality can be inspired by publicly described RobOps themes, but do not attempt an exact replica of any proprietary platform"
      ]
    },
    "sources_of_inspiration_non_copied": {
      "capability_themes": [
        "Robot orchestration with a shared map and common API",
        "Developer focused robot ops console with monitoring, diagnostics, and safe controls",
        "Mission tracking and historical analysis",
        "Facility spatial view connecting robots, zones, and operational context",
        "RTLS style tracking of robots and non robot assets on one screen",
        "Copilot style conversational analytics for robot ops"
      ],
      "public_concepts_reference": {
        "space_intelligence_like": "Facility centric orchestration and a holistic view that combines robotic and spatial operational signals",
        "ground_control_like": "Developer portal style management of robots, credentials, integrations, and remote ops",
        "mission_tracking_like": "Track missions, status, KPIs, and drilldown timelines",
        "api_like": "REST and streaming style access to robot data and actions",
        "configuration_like": "Configuration as code for customizing widgets and views"
      }
    }
  },
  "tech_stack": {
    "frontend": {
      "framework": "Next.js 14",
      "language": "TypeScript",
      "ui": "Tailwind CSS plus shadcn ui",
      "state": "TanStack Query for server state, Zustand for local UI state",
      "charts": "Recharts",
      "maps": "MapLibre GL or Leaflet for facility maps plus custom 2D floorplan overlay",
      "realtime": "WebSocket or Server Sent Events client",
      "auth": "NextAuth or custom JWT",
      "forms": "React Hook Form plus Zod validation"
    },
    "backend": {
      "runtime": "Node.js 20",
      "framework": "NestJS or Fastify",
      "database": "PostgreSQL for core entities, TimescaleDB extension optional for time series telemetry",
      "cache": "Redis for sessions and hot dashboards",
      "message_bus": "NATS or Kafka optional for streaming ingestion",
      "storage": "S3 compatible for logs and artifacts",
      "observability": "OpenTelemetry tracing, structured logs, metrics endpoint"
    },
    "deployment": {
      "local_dev": "Docker Compose",
      "prod": "Kubernetes optional, or container based hosting",
      "security": "TLS everywhere, secrets in vault, least privilege roles"
    }
  },
  "domain_model": {
