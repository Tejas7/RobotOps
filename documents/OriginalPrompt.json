  "api_spec_mock": {
    "base_url": "http://localhost:4000/api",
    "rest_endpoints": [
      { "method": "GET", "path": "/tenants/me", "desc": "Get current tenant context" },
      { "method": "GET", "path": "/sites", "desc": "List sites" },
      { "method": "GET", "path": "/floorplans?site_id={id}", "desc": "List floorplans for a site" },
      { "method": "GET", "path": "/robots?site_id={id}&status=online&tag=amr", "desc": "List robots with filters" },
      { "method": "GET", "path": "/robots/{id}", "desc": "Robot detail" },
      {
        "method": "POST",
        "path": "/robots/{id}/actions",
        "desc": "Request robot action like dock or pause mission",
        "body": { "action": "dock | pause | resume | speed_limit", "params": {} }
      },
      { "method": "GET", "path": "/missions?site_id={id}&state=running", "desc": "List missions" },
      {
        "method": "POST",
        "path": "/missions",
        "desc": "Create a mission",
        "body": { "name": "string", "type": "string", "priority": "string", "site_id": "uuid", "assigned_robot_id": "uuid or null", "route": {} }
      },
      { "method": "GET", "path": "/missions/{id}", "desc": "Mission detail" },
      { "method": "GET", "path": "/incidents?site_id={id}&status=open", "desc": "List incidents" },
      { "method": "POST", "path": "/incidents/{id}/ack", "desc": "Acknowledge incident" },
      { "method": "POST", "path": "/incidents/{id}/resolve", "desc": "Resolve incident with note", "body": { "note": "string" } },
      { "method": "GET", "path": "/audit?resource_type=robot&resource_id={id}", "desc": "Audit log query" },
      { "method": "GET", "path": "/telemetry/robot/{id}?metric=battery&from=...&to=...", "desc": "Telemetry timeseries for a robot metric" },
      { "method": "GET", "path": "/rtls/assets?site_id={id}", "desc": "List assets tracked on floorplan" },
      { "method": "GET", "path": "/copilot/thread/{id}", "desc": "Fetch copilot conversation thread" },
      { "method": "POST", "path": "/copilot/thread", "desc": "Create copilot thread" },
      { "method": "POST", "path": "/copilot/message", "desc": "Send user message and receive assistant response", "body": { "thread_id": "uuid", "content": "string" } }
    ],
    "realtime": {
      "protocol": "WebSocket",
      "channels": [
        { "name": "robots.live", "payload": "robot pose, status, battery, last_seen" },
        { "name": "incidents.live", "payload": "new and updated incidents" },
        { "name": "missions.live", "payload": "mission state updates and key events" },
        { "name": "telemetry.live", "payload": "selected metrics streaming" }
      ]
    }
  },
