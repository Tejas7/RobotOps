  "security_and_roles": {
    "roles": [
      { "name": "Owner", "permissions": "all" },
      {
        "name": "OpsManager",
        "permissions": [
          "robots.read",
          "missions.read",
          "missions.write",
          "incidents.read",
          "incidents.write",
          "teleop.start",
          "teleop.stop",
          "analytics.read"
        ]
      },
      {
        "name": "Engineer",
        "permissions": [
          "robots.read",
          "robots.control",
          "missions.read",
          "incidents.read",
          "audit.read",
          "integrations.read",
          "config.read",
          "config.write"
        ]
      },
      {
        "name": "Operator",
        "permissions": [
          "robots.read",
          "missions.read",
          "incidents.read",
          "incidents.ack",
          "teleop.start",
          "teleop.stop"
        ]
      },
      {
        "name": "Viewer",
        "permissions": [
          "robots.read",
          "missions.read",
          "analytics.read"
        ]
      }
    ],
    "authn": {
      "modes": [
        "email_password",
        "sso_saml",
        "oidc"
      ],
      "session": {
        "token_type": "jwt",
        "rotation_minutes": 30,
        "refresh": true
      }
    },
    "authz": {
      "enforcement": "backend enforced RBAC plus tenant isolation everywhere",
      "notes": [
        "All queries must be filtered by tenant_id",
        "Robot control endpoints require robots.control",
        "Audit log access requires audit.read",
        "Teleoperation requires teleop.start"
      ]
    }
  },
  "ui_design_system": {
    "brand": {
      "name": "RobotOps",
      "visual_direction": "Wealthsimple inspired fintech minimalism applied to robotics operations",
      "goals": [
        "Calm, modern, premium",
        "Extreme clarity with minimal visual noise",
        "Soft surfaces, subtle depth, clean typography",
        "High trust and accessibility"
      ],
      "non_goals": [
        "No industrial control room styling",
        "No cyber neon, heavy grids, or harsh contrast",
        "No copying any vendor UI layouts or icons"
      ]
    },
    "theme": {
      "modes": [
        "light",
        "dark"
      ],
      "default_mode": "light",
      "color_strategy": {
        "rule_1": "Use neutral base surfaces with one primary accent and one success and warning family",
        "rule_2": "Avoid more than one accent color in a single screen",
        "rule_3": "Use semantic colors sparingly and only for status",
        "rule_4": "Prefer subtle tinted backgrounds for status over saturated fills"
      },
      "typography": {
        "style": "Clean fintech typography, large readable headings, generous line height",
        "scale": {
          "display": "Used only on Overview key metrics",
          "h1": "Page title",
          "h2": "Section title",
          "h3": "Card title",
          "body": "Default",
          "caption": "Meta and helper text"
        },
        "rules": [
          "Use sentence case everywhere",
          "Avoid all caps except tiny chips",
          "Numbers use tabular lining figures if available"
        ]
      },
      "spacing": {
        "philosophy": "Whitespace is the brand",
        "rules": [
          "Use an 8px spacing system",
          "Cards have generous padding",
          "Tables have comfortable row height"
        ]
      },
      "shape": {
        "radius": {
          "cards": "large rounded corners",
          "buttons": "pill or near pill",
          "inputs": "rounded"
        },
        "shadows": {
          "style": "Very soft elevation, almost invisible",
          "rules": [
            "No heavy drop shadows",
            "Use borders and surface contrast first, shadow second"
          ]
        }
      }
    },
    "layout": {
      "overall": "Simple left navigation with top header",
      "nav": {
        "left_sidebar": {
          "style": "Minimal icons, lots of spacing, clear active state",
          "items": [
            "Overview",
            "Fleet",
            "Missions",
            "Facility",
            "Incidents",
            "Teleoperation",
            "Analytics",
            "Integrations",
            "Developer",
            "Settings"
          ]
        },
        "top_header": {
          "elements": [
            "Site selector",
            "Time range selector",
            "Global search",
            "Notifications",
            "User menu"
          ],
          "style_rules": [
            "Sticky header",
            "Subtle bottom border",
            "No loud background"
          ]
        }
      },
      "grid": {
        "max_width": "Use a centered max width on content heavy pages, full width only for maps",
        "rules": [
          "Prefer two column card layouts on desktop",
          "Maps and tables can go full width"
        ]
      }
    },
    "components": {
      "buttons": {
        "primary": "Solid fill, high contrast text, rounded",
        "secondary": "Subtle outline or tinted background",
        "tertiary": "Text only",
        "rules": [
          "No aggressive gradients",
          "Disable states are clear",
          "Loading shows subtle spinner"
        ]
      },
      "cards": {
        "style": "Clean bordered cards with soft surface",
        "rules": [
          "Card headers are small and calm",
          "Keep cards simple, avoid dense widgets"
        ]
      },
      "tables": {
        "style": "Fintech grade tables with strong readability",
        "rules": [
          "Sticky header row",
          "Row hover is subtle",
          "Inline filters are minimal",
          "Use a detail drawer instead of cramming columns"
        ]
      },
      "chips_and_status": {
        "chip_style": "Pill chips with minimal fill",
        "robot_status": {
          "online": "success",
          "offline": "neutral",
          "degraded": "warning",
          "maintenance": "info",
          "emergency_stop": "danger"
        },
        "rules": [
          "Status shows as a small chip plus an icon",
          "Never rely on color alone"
        ]
      },
      "charts": {
        "style": "Minimal chart chrome, light grid lines, strong labels",
        "rules": [
          "Show tooltips on hover",
          "Prefer simple line and bar charts",
          "Avoid busy multi series unless necessary"
        ]
      },
      "motion": {
        "style": "Subtle micro interactions",
        "rules": [
          "Use small fades and slide ups on drawers",
          "Avoid bouncy animations",
          "Use skeleton loading placeholders"
        ]
      },
      "map": {
        "style": "Clean map with minimal overlays",
        "rules": [
          "Layer toggles are inside a calm panel",
          "Robot markers are simple, not futuristic",
          "Use tasteful trails for movement playback"
        ]
      }
    },
    "content_and_copy": {
      "tone": "Clear, friendly, direct",
      "rules": [
        "Prefer short labels",
        "Use helper text where needed",
        "Avoid jargon on overview pages, keep jargon in detail views"
      ],
      "empty_states": [
        "Use a friendly one line explanation",
        "Offer a single primary action"
      ]
    },
    "accessibility": {
      "targets": [
        "WCAG AA contrast in both modes",
        "Keyboard navigable tables, drawers, and map controls",
        "Screen reader labels on all controls"
      ]
    }
  },
  "implementation_notes_for_codex": {
    "design_guardrails": [
      "Do not replicate any existing product layout",
      "Use original spacing, component styling, and iconography",
      "Prioritize whitespace and calm surfaces",
      "Keep pages intentionally uncluttered, use drawers for drill down"
    ],
    "recommended_component_library": {
      "base": "shadcn ui",
      "icons": "lucide react",
      "animation": "framer motion",
      "charts": "recharts"
    },
    "page_level_rules": [
      "Overview is card based with large friendly KPIs",
      "Fleet uses a table plus right side drawer for robot details",
      "Facility uses full width map with minimal overlay panels",
      "Incidents use a list plus timeline drawer",
      "Developer is documentation like with clean code blocks"
    ]
  },
